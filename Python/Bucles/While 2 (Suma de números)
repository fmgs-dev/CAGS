#Programa que suma números introducidos por el usuario hasta que este introduzca el número 0 para salir del programa

#Incializa variable con un valor que hace que el programa entre en el bucle While
Numero = 1

#Inicializa la suma a cero
Suma = 0

#Inicio del bucle
while(Numero != 0):
	Numero = int(input("\nIntroduce un número: "))
	Suma = Suma + Numero
	print("La suma, de momento es: ", Suma)
#Fin del bucle While



print("\nLa suma total es:", Suma)